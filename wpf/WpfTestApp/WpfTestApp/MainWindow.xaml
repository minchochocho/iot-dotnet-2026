<hc:GlowWindow
    x:Class="WpfTestApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
    Title="TeamPlay Mate"
    Width="1300"
    Height="800"
    MinWidth="1100"
    MinHeight="700"
    Background="#F5F7FA"
    WindowStartupLocation="CenterScreen"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <hc:GlowWindow.Resources>

        <!-- 컨버터: HEX 문자열 → Brush -->
        <local:HexToBrushConverter x:Key="HexToBrushConverter"
            xmlns:local="clr-namespace:WpfTestApp"/>

        <!-- 링크 버튼 스타일 -->
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#2563EB"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </hc:GlowWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===================== SIDEBAR ===================== -->
        <Border Grid.Column="0"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,1,0">

            <DockPanel LastChildFill="True">

                <!-- Logo -->
                <hc:Card DockPanel.Dock="Top"
                         Margin="12,20,12,8"
                         Padding="14,12"
                         BorderThickness="0"
                         Background="Transparent"
                         Effect="{x:Null}">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40"
                                Height="40"
                                CornerRadius="20"
                                Background="#F472B6">
                            <TextBlock Text="TM"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="teamplay mate"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="#111827"/>
                            <TextBlock Text="프로젝트 관리"
                                       FontSize="11"
                                       Foreground="#9CA3AF"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </hc:Card>

                <!-- User profile -->
                <hc:Card DockPanel.Dock="Bottom"
                         Margin="12,0,12,16"
                         Padding="14,12"
                         BorderThickness="0"
                         Background="#F9FAFB">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="38"
                                Height="38"
                                CornerRadius="19"
                                Background="#E5E7EB">
                            <TextBlock Text="U"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="사용자"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="#111827"/>
                            <TextBlock Text="user@example.com"
                                       FontSize="11"
                                       Foreground="#9CA3AF"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                </hc:Card>

                <!-- Divider -->
                <Border DockPanel.Dock="Top"
                        Height="1"
                        Background="#F3F4F6"
                        Margin="0,0,0,4"/>

                <!-- Menu -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,16">

                        <TextBlock Text="메뉴"
                                   Margin="20,8,20,6"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="#9CA3AF"/>

                        <ListBox x:Name="MainMenu"
                                 Margin="8,0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectedIndex="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="12,9"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd"
                                                        CornerRadius="8"
                                                        Padding="{TemplateBinding Padding}"
                                                        Background="Transparent">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                            <Condition Property="IsSelected" Value="False"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <!-- 대시보드 -->
                            <ListBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE80F;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="15" Width="22"
                                               TextOptions.TextFormattingMode="Ideal"
                                               Foreground="#2563EB"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Text="대시보드" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#2563EB" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>

                            <!-- 내 작업 -->
                            <ListBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7C3;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="15" Width="22"
                                               TextOptions.TextFormattingMode="Ideal"
                                               Foreground="#9CA3AF"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Text="내 작업" FontSize="13"
                                               Foreground="#374151" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>

                            <!-- 프로젝트 -->
                            <ListBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8F1;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="15" Width="22"
                                               TextOptions.TextFormattingMode="Ideal"
                                               Foreground="#9CA3AF"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Text="프로젝트" FontSize="13"
                                               Foreground="#374151" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>

                            <!-- 팀 -->
                            <ListBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE716;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="15" Width="22"
                                               TextOptions.TextFormattingMode="Ideal"
                                               Foreground="#9CA3AF"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Text="팀" FontSize="13"
                                               Foreground="#374151" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>

                            <!-- 보고서 -->
                            <ListBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE9D9;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="15" Width="22"
                                               TextOptions.TextFormattingMode="Ideal"
                                               Foreground="#9CA3AF"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Text="보고서" FontSize="13"
                                               Foreground="#374151" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ListBoxItem>

                        </ListBox>

                        <Border Height="1"
                                Background="#F3F4F6"
                                Margin="16,16,16,12"/>

                        <TextBlock Text="프로젝트"
                                   Margin="20,0,20,6"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="#9CA3AF"/>

                        <ItemsControl ItemsSource="{Binding Projects}"
                                      Margin="8,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,9"
                                            CornerRadius="6"
                                            Margin="2,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Ellipse Width="7"
                                                     Height="7"
                                                     Fill="#3B82F6"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,10,0"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontSize="12"
                                                       Foreground="#374151"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Count}"
                                                       FontSize="11"
                                                       Foreground="#9CA3AF"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Margin="20,12,20,0"
                                HorizontalAlignment="Left"
                                Style="{StaticResource ButtonCustom}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Click="NewProject_Click"
                                Foreground="#2563EB"
                                FontSize="12">
                            <TextBlock>
                                <Run Text="+" FontSize="15" FontWeight="Bold"/>
                                <Run Text=" 새 프로젝트 만들기"/>
                            </TextBlock>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ===================== DASHBOARD CONTENT ===================== -->
        <hc:ScrollViewer Grid.Column="1"
                         IsInertiaEnabled="True"
                         VerticalScrollBarVisibility="Auto"
                         Background="#F5F7FA">
            <StackPanel Margin="32,28,32,32">

                <!-- Header -->
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Today}"
                                   FontSize="11"
                                   Foreground="#9CA3AF"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="대시보드"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                        <TextBlock Text="프로젝트와 작업의 진행 상황을 한눈에 확인하세요"
                                   FontSize="13"
                                   Foreground="#9CA3AF"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource ButtonCustom}"
                                Height="38"
                                Padding="16,0"
                                Margin="0,0,10,0"
                                Background="White"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                Content="상세 보고서"
                                Click="DetailReport_Click"/>
                        <Button Style="{StaticResource ButtonPrimary}"
                                Height="38"
                                Padding="16,0"
                                Content="+ 새 프로젝트"
                                Click="NewProject_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Summary cards -->
                <ItemsControl ItemsSource="{Binding SummaryCards}"
                              Margin="0,0,-12,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <hc:Card Margin="0,0,12,0"
                                     Padding="0"
                                     BorderThickness="0"
                                     Cursor="Hand"
                                     Effect="{DynamicResource EffectShadow2}">
                                <hc:Card.RenderTransform>
                                    <TranslateTransform x:Name="CardMove"/>
                                </hc:Card.RenderTransform>
                                <hc:Card.Triggers>
                                    <EventTrigger RoutedEvent="UIElement.MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="CardMove"
                                                                 Storyboard.TargetProperty="Y"
                                                                 To="-6" Duration="0:0:0.18">
                                                    <DoubleAnimation.EasingFunction>
                                                        <SineEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="UIElement.MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="CardMove"
                                                                 Storyboard.TargetProperty="Y"
                                                                 To="0" Duration="0:0:0.18">
                                                    <DoubleAnimation.EasingFunction>
                                                        <SineEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </hc:Card.Triggers>

                                <Grid>
                                    <!-- 상단 컬러 바 -->
                                    <Border Height="4" VerticalAlignment="Top" CornerRadius="4,4,0,0"
                                            Background="{Binding Color, Converter={StaticResource HexToBrushConverter}}"/>

                                    <StackPanel Margin="16,18,16,20"
                                                HorizontalAlignment="Center">
                                        <!-- 숫자 (크게, 가운데) -->
                                        <TextBlock Text="{Binding Value}"
                                                   FontSize="30"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{Binding Color, Converter={StaticResource HexToBrushConverter}}"/>

                                        <!-- 아이콘 + 레이블 한 줄 (가운데 정렬) -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,8,0,0">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="14"
                                                       TextOptions.TextFormattingMode="Ideal"
                                                       Foreground="{Binding Color, Converter={StaticResource HexToBrushConverter}}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="13"
                                                       Foreground="#6B7280"
                                                       Margin="6,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </hc:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Chart + Activity -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Task progress -->
                    <hc:Card Grid.Column="0"
                             Margin="0,0,12,0"
                             BorderThickness="0"
                             Effect="{DynamicResource EffectShadow2}">
                        <StackPanel Margin="24,20,24,20">
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="작업 진행률"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           VerticalAlignment="Center"/>
                                <Button Content="자세히 보기"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource LinkButtonStyle}"
                                        Click="ViewChartDetail_Click"/>
                            </Grid>

                            <lvc:PieChart Series="{Binding TaskProgressSeries}"
                                          LegendLocation="Bottom"
                                          InnerRadius="70"
                                          Height="300"
                                          HoverPushOut="8"/>
                        </StackPanel>
                    </hc:Card>

                    <!-- Recent activity -->
                    <hc:Card Grid.Column="1"
                             BorderThickness="0"
                             Effect="{DynamicResource EffectShadow2}">
                        <StackPanel Margin="24,20,24,20">
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="최근 활동"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           VerticalAlignment="Center"/>
                                <Button Content="모두 보기"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource LinkButtonStyle}"
                                        Click="ViewAllActivities_Click"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding RecentActivities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 타임라인 선 + 점 -->
                                            <Grid>
                                                <!-- 세로 연결선 -->
                                                <Rectangle Width="2"
                                                           Fill="#E5E7EB"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,14,0,-4"/>
                                                <!-- 색상 점 -->
                                                <Ellipse Width="12" Height="12"
                                                         VerticalAlignment="Top"
                                                         HorizontalAlignment="Center"
                                                         Margin="0,6,0,0"
                                                         Fill="{Binding StatusColor, Converter={StaticResource HexToBrushConverter}}"/>
                                            </Grid>

                                            <!-- 내용 + 뱃지 -->
                                            <Grid Grid.Column="1" Margin="4,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="12"
                                                               Foreground="#374151"
                                                               TextWrapping="Wrap"
                                                               LineHeight="18"/>
                                                    <TextBlock Text="{Binding TimeAgo}"
                                                               FontSize="11"
                                                               Foreground="#9CA3AF"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        CornerRadius="10"
                                                        Padding="8,3"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Top"
                                                        Background="{Binding StatusBgColor, Converter={StaticResource HexToBrushConverter}}">
                                                    <TextBlock Text="{Binding Status}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding StatusTextColor, Converter={StaticResource HexToBrushConverter}}"/>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </hc:Card>
                </Grid>

            </StackPanel>
        </hc:ScrollViewer>

    </Grid>
</hc:GlowWindow>
