<Page x:Class="WpfBasic02Navi.Sub02Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfBasic02Navi"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Sub02Page"
      Loaded="Page_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="100*"/>
            <RowDefinition Height="25*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Label Content="일반 작업화면" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5,0"/>

        <DataGrid x:Name="DgrEmployees" Grid.Row="1" Grid.Column="0" 
                  AutoGenerateColumns="True" Margin="5"
                  IsReadOnly="True" SelectionMode="Single" 
                  ItemsSource="{Binding Employees}"
                  SelectedItem="{Binding SelectedEmployee}">
        </DataGrid>
        <GroupBox Grid.Row="1" Grid.Column="1" Margin="5" 
                  Header="상세정보"
                  DataContext="{Binding SelectedItem, ElementName=DgrEmployees}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" Margin="10" Text="{Binding Id}" />
                <TextBox Grid.Row="1" Margin="10" Text="{Binding Name}"/>
                <ComboBox Grid.Row="2" Margin="10"
                          Background="White"
                          ItemsSource="{Binding DataContext.Departments, 
                          RelativeSource={RelativeSource AncestorType=Page}}" 
                          SelectedItem="{Binding Department}"/>
                <TextBox Grid.Row="3" Margin="10" Text="{Binding Salary}"/>
                <DatePicker Grid.Row="4" Margin="10, 14" Text="{Binding HireDate, Mode=TwoWay}" />
                <CheckBox Grid.Row="5" Margin="10" IsChecked="{Binding IsActive}"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="신규" Margin="5" Width="70" Height="50"/>
            <Button Content="저장" Margin="5" Width="70" Height="50"/>
            <Button Content="삭제" Margin="5" Width="70" Height="50"/>
        </StackPanel>

    </Grid>
</Page>