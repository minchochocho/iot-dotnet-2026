<Page x:Class="WpfBasic02Navi.Sub04Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfBasic02Navi"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Sub04Page"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Label Content="정통윈폼 이벤트 체인 테스트" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5,0"/>

        <GroupBox x:Name="GrbInfo" Grid.Row="1" Grid.Column="1" Margin="5" Header="상세정보">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBox x:Name="TxtSpeed" Grid.Row="0" Margin="10,5" VerticalAlignment="Center" />

                <StackPanel Grid.Row="1" Margin="10, 5">
                    <Border Height="20" CornerRadius="3" Margin="0,0,0,5">
                        <Border.Background>
                            <SolidColorBrush x:Name="ScbColor"/>
                        </Border.Background>
                    </Border>

                    <TextBox x:Name="TxtColor" TextChanged="TxtColor_TextChanged" />
                </StackPanel>

                <TextBox Grid.Row="2" Margin="10,5" VerticalAlignment="Center" />
                <TextBox Grid.Row="3" Margin="10,5" VerticalAlignment="Center" />
                <TextBox Grid.Row="4" Margin="10,5" VerticalAlignment="Center" />
                <CheckBox Grid.Row="5" Content="확인 선택" Margin="10,5" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="신규" Margin="5" Width="70" Height="40"/>
            <Button Content="저장" Margin="5" Width="70" Height="40"/>
            <Button Content="삭제" Margin="5" Width="70" Height="40"/>
        </StackPanel>
    </Grid>
</Page>