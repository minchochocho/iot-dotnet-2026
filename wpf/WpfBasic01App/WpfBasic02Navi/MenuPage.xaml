<Page x:Class="WpfBasic02Navi.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfBasic02Navi"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page1">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal"> 
            <Button x:Name="BtnMenu01" Content="Controls Page" Margin="10, 10, 5, 10" Width="148" Click="BtnMenu01_Click"/>
            <Button x:Name="BtnMenu02" Content="Content Page" Margin="5, 10, 5, 10" Width="148" Click="Button_Click"/>
            <Button x:Name="BtnMenu03" Content="Binding Basic" Margin="5, 10, 5, 10" Width="148" Click="BtnMenu03_Click"/>
            <Button x:Name="BtnMenu04" Content="Page04" Margin="5, 10, 5, 10" Width="148" Click="BtnMenu04_Click"/>
            <Button Content="Page05" Margin="5, 10, 10, 10" Width="148"/>
        </StackPanel>

        <Grid Grid.Row ="1">
            <Button Content="Page06" Margin="10,10,582,80" />
            <Button Content="Page07" Margin="223,10,352,80" />
            <Button Content="Page08" Margin="453,10,10,80" />
            <Button Content="Page09" Margin="10,75,209,15" />
            <Button Content="Page10" Margin="596,75,10,15"/>
        </Grid>

        <DockPanel Grid.Row="2">
            <Button Content="Page11" DockPanel.Dock="Top" />
            <Button Content="Page12" DockPanel.Dock="Left"/>
            <Button Content="Page13" DockPanel.Dock="Right" />
            <Button Content="Page14" DockPanel.Dock="Bottom"/>
            <Button Content="Page15" />
        </DockPanel>
    </Grid>
</Page>
