<Page x:Class="WpfBasic02Navi.Sub01Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfBasic02Navi"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="단순 컨트롤 페이지" Loaded="Page_Loaded" >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Content="단순 컨트롤" Grid.Row="0" Grid.Column="0"/>

        <StackPanel Grid.Row="1" Grid.Column="0">
            <Label Content="레이블 컨트롤(기본 padding)"/>
            <TextBlock Text="텍스트 블록 컨트롤(padding 없음)"/>
            <TextBox Text="일반 텍스트박스 컨트롤"/>
            <PasswordBox Password="123456"/>
            <Slider x:Name="SlideerTest" Minimum="0" Maximum="100" TickFrequency="10" Value="20"/>
            <ProgressBar Minimum="0" Maximum="100" Value="{Binding Value, ElementName=SlideerTest}" Height="20"/>
            <CheckBox Content="체크박스 컨트롤"/>
            <RadioButton Content="라디오 버튼 컨트롤"/>
            <Button Content= "버튼 컨트롤"/>

        </StackPanel>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Image Source="cat.jpg" Width="200" Height="100" Stretch="Uniform" Margin="-2,55,2,55"/>
            <MediaElement  x:Name="MediaPlayer" Source="sample01.mp4" Width="200" Height="100"
                          LoadedBehavior="Manual" Margin="1,55,-1,55" Grid.Column="1"/>
        </Grid>

        <Canvas Grid.Row="2" Grid.Column="0" Background="LightGray" ClipToBounds="True">
            <Rectangle Width="100" Height="100" 
                       Fill="Red" Stroke="CadetBlue" 
                       StrokeThickness="5" Canvas.Left="-10" Canvas.Top="-40"/>
            <Ellipse Width="30" Height="27"
                Fill="pink" Stroke="Yellow" 
                StrokeDashArray="2" StrokeDashCap="Round" 
                StrokeThickness="5" Canvas.Left="135" Canvas.Top="73" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Ellipse Width="30" Height="31"
                Fill="pink" Stroke="Yellow" 
                StrokeDashArray="2" StrokeDashCap="Round" 
                StrokeThickness="5" Canvas.Left="237" Canvas.Top="84" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Ellipse Width="48" Height="43"
                Fill="red" Stroke="Yellow" 
                StrokeDashArray="2" StrokeDashCap="Round" 
                StrokeThickness="5" Canvas.Left="205" Canvas.Top="128" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Ellipse.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="62.204"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Width="100" Height="100"
                     Fill="pink" Stroke="Yellow" 
                     StrokeDashArray="2" StrokeDashCap="Round" 
                     StrokeThickness="5" Canvas.Left="150" Canvas.Top="55" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Ellipse Width="48" Height="43"
                Fill="red" Stroke="Yellow" 
                StrokeDashArray="2" StrokeDashCap="Round" 
                StrokeThickness="5" Canvas.Left="133" Canvas.Top="109" HorizontalAlignment="Left" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="62.204"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <Grid Grid.Row="2" Grid.Column="1">
            <Button Margin="50" Click="Button_Click" Content="Press Me">
                <!--Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Rectangle RadiusX="12" RadiusY="12" 
                           Fill="#25A3FB" Stroke="DarkBlue" StrokeThickness="4">
                                <Rectangle.Effect>
                                    <DropShadowEffect Color="DarkGray"
                                                      BlurRadius="15"
                                                      ShadowDepth="5"
                                                      Direction="320"
                                                      Opacity="0.7"/>
                                </Rectangle.Effect>
                            </Rectangle>
                            <Label Content="{TemplateBinding Content}" 
                                   Foreground="White" FontSize="20" FontWeight="ExtraBold" 
                                   
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Button.Template-->
            </Button>
        </Grid>

    </Grid>
</Page>
