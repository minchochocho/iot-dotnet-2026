        xmlns:local="clr-namespace:WpfBasic01App"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Rectangle HorizontalAlignment="Left" Height="205" Stroke="#FF838D9C" VerticalAlignment="Top" Width="301" Margin="181,90,0,0" RenderTransformOrigin="0.5,0.5" StrokeThickness="2" Fill="#FFE4E7F3" RadiusX="23.572" RadiusY="23.572">
            <Rectangle.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.002"/>
                    <TranslateTransform/>
