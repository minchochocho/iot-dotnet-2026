<Window x:Class="WpfCafeKiosk.MenuOptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:WpfCafeKiosk"
        mc:Ignorable="d"
        ResizeMode="NoResize" WindowStyle="None" 
        Background="Transparent" AllowsTransparency ="True" WindowStartupLocation="CenterOwner"
        Title="MenuOptionWindow" Height="350" Width="320">
    <materialDesign:Card UniformCornerRadius="10" Padding="0">
        <Grid>
            <Grid.RowDefinitions>

                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
                <RowDefinition Height="70"/>

            </Grid.RowDefinitions>
            
            <!-- 상품정보 영역 -->
            <Grid Grid.Row="0" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Image x:Name="ImgMenu" 
                       Width="150" Height="150" 
                       Stretch="UniformToFill" 
                       Source="/images/iceamericano.png">
                    <Image.Clip>
                        <RectangleGeometry Rect="0,0,150,150" RadiusX="5" RadiusY="5"/>
                    </Image.Clip>
                </Image>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtMenuName" Text="아이스아메리카노" FontSize="16" 
                               FontWeight="Bold" Foreground="DimGray" TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock x:Name="TxtPrice" Text="3,500원" FontSize="14" FontWeight="Bold" Foreground="#7D9950" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
            
            <!-- 수량 영역 -->
            <Border Grid.Row="1" BorderThickness="0,1,0,1" BorderBrush="#EEEEEE" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Label Content="수량" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="DimGray" FontFamily="Bold"/>
                    <Button Width="30" Height="30" Padding="0" Content="-" FontWeight="Bold"  Background="ForestGreen" BorderThickness="0"/>
                    <TextBlock Text="1" Width="50"   VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                    <Button Width="30" Height="30" Padding="0" Content="+" FontWeight="Bold"  Background="ForestGreen" BorderThickness="0"/>
                </StackPanel>
            </Border>
            
            <!-- 버늩영역 -->
            <Grid Grid.Row="2" Margin="20,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="주문 담기" Background="ForestGreen" Foreground="White" FontWeight="Bold" Height="50" BorderThickness="0"></Button>

                <Button Grid.Column="2" Content="취소" Background="#5D5353" Foreground="White" FontWeight="Bold" Height="50" BorderThickness="0" Click="Button_Click"/>
            </Grid>
        </Grid>
    </materialDesign:Card>
</Window>
