<Window x:Class="WpfCafeKiosk.OrderConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:WpfCafeKiosk"
        mc:Ignorable="d"
        Title="OrderConfirmWindow" Height="350" Width="320"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" AllowsTransparency="True" Background="Transparent" Loaded="Window_Loaded">
    <materialDesign:Card UniformCornerRadius="10" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="65"/>
            </Grid.RowDefinitions>

            <!-- 타이틀 -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center">
                <TextBlock Text="주문리스트" FontSize="20" FontWeight="Bold" Foreground="ForestGreen" TextAlignment="Center"/>
                <TextBlock Text="주문리스트를 확인 해 주세요" FontSize="13" FontWeight="Bold" Foreground="DimGray" TextAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- 주문 리스트 -->
            <Grid Grid.Row="1" Margin="30,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="메뉴" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="수량" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="가격" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- 주문 리스트 -->
                <ListBox x:Name="LstConfirmOrder" Grid.Row="1" BorderThickness="0" Background="Transparent" FontSize="12" HorizontalContentAlignment="Stretch">
                    <!-- 메인윈도우 리스트박스 재활용 -->
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="35" >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding MenuName}" VerticalAlignment="Center" FontWeight="Bold" Foreground="DimGray"></TextBlock>
                                <TextBlock Grid.Column="1" Text="{Binding Count, StringFormat={}{0:N0}}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#7D9950"></TextBlock>
                                <TextBlock Grid.Column="2" Text="{Binding TotalPrice, StringFormat={}{0:N0}원}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#7D9950"></TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>


            <!-- 합계 영역 -->
            <Grid Grid.Row="2" Margin="20,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="총 수량" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TxtTotalCount" Text="1잔" Foreground="#7D9950" FontWeight="Bold" TextAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="총 결제금액" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TxtTotalAmount" Text="18000원" Foreground="#7D9950" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="3" Margin="25,2,25,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnOk" Grid.Column="0" Click="BtnOk_Click" Content="확  인" Background="#7D9950" Foreground="White" FontWeight="Bold" BorderThickness="0"
                        Height="50"/>
                <Button x:Name="BtnCancel" Click="BtnCancel_Click" Grid.Column="2" Content="취   소" Background="#5D5353" Foreground="White" FontWeight="Bold" BorderThickness="0"
                        Height="50"/>
            </Grid>
        </Grid>
    </materialDesign:Card>
</Window>
