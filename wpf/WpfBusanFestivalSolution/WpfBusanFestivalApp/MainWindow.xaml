<mah:MetroWindow 
        x:Class="WpfBusanFestivalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:WpfBusanFestivalApp"
        mc:Ignorable="d"
        Title="부산 축제정보 V1.0"
        Width="1100"
        Height="680"
        MinWidth="800"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        BorderThickness="1"
        Loaded="MainWindow_Loaded">

    <mah:MetroWindow.Resources>
        <!-- 헤더 그라디언트 -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2C2C2C" Offset="0"/>
            <GradientStop Color="#3A3A3A" Offset="0.5"/>
            <GradientStop Color="#444444" Offset="1"/>
        </LinearGradientBrush>

        <!-- 스테퍼 ± 버튼 스타일 -->
        <Style x:Key="StepperBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8E8E8"/>
                                <Setter Property="Foreground" Value="#222222"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 검색 버튼 스타일 -->
        <Style x:Key="SearchButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6B8EDB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#222222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid 헤더 스타일 -->
        <Style x:Key="DgHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#6B8EDB"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <!-- DataGrid 행 스타일 -->
        <Style x:Key="DgRowStyle" TargetType="DataGridRow">
            <Setter Property="Height" Value="52"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="Foreground" Value="#1A1A1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid 셀 스타일 -->
        <Style x:Key="DgCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#1A1A1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <DockPanel Background="#F2F2F2">

        <!-- 하단 상태바 -->
        <Border DockPanel.Dock="Bottom"
                Background="#6B8EDB"
                Height="30">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="14,0">
                    <Ellipse Width="8" Height="8" Fill="#9E9E9E" Margin="0,0,6,0"/>
                    <TextBlock Text="공공데이터포털 Open API 활용"
                               Foreground="White"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <Separator Background="White" />
                    <StatusBarItem>
                        <TextBlock x:Name="SbiStatus"/>
                    </StatusBarItem>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="부산 축제정보 v1.0"
                           Foreground="#666666"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0"/>
            </Grid>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 헤더 배너 -->
            <Border Grid.Row="0" Background="#6B8EDB">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Background="#68707D"
                                CornerRadius="8"
                                Width="40" Height="40"
                                Margin="0,0,12,0">
                            <TextBlock Text="🎉" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="부산 축제정보"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Busan Festival Information"
                                       Foreground="#B3D9FF"
                                       FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 검색 영역 -->
            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="#DDDDDD"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#888888"
                                   FontSize="13">
                            <Run Text="총 "/>
                            <Run x:Name="RunTotalCount" Text="0" FontWeight="Bold" Foreground="#3A3A3A"/>
                            <Run Text=" 건의 축제 데이터"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">

                        <mah:NumericUpDown x:Name="NumPageNo"
                                           Visibility="Collapsed"
                                           Value="1"
                                           Minimum="1"/>
                        <mah:NumericUpDown x:Name="NumOfRows"
                                           Visibility="Collapsed"
                                           Value="10"
                                           Minimum="10"
                                           Maximum="100"
                                           Interval="10"/>

                        <!-- 페이지 스테퍼 -->
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,16,0">
                            <TextBlock Text="페이지"
                                       Foreground="#888888"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Border Background="#F7F7F7"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Height="36">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="2,0">
                                    <Button x:Name="BtnPageMinus"
                                            Content="−"
                                            Style="{StaticResource StepperBtnStyle}"
                                            Click="BtnPageMinus_Click"/>
                                    <TextBlock x:Name="TxtPageNo"
                                               Text="1"
                                               Width="36"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#333333"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="BtnPagePlus"
                                            Content="+"
                                            Style="{StaticResource StepperBtnStyle}"
                                            Click="BtnPagePlus_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 결과수 스테퍼 -->
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,12,0">
                            <TextBlock Text="결과수"
                                       Foreground="#888888"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <Border Background="#F7F7F7"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Height="36">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="2,0">
                                    <Button x:Name="BtnRowsMinus"
                                            Content="−"
                                            Style="{StaticResource StepperBtnStyle}"
                                            Click="BtnRowsMinus_Click"/>
                                    <TextBlock x:Name="TxtRows"
                                               Text="10"
                                               Width="36"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#333333"
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="BtnRowsPlus"
                                            Content="+"
                                            Style="{StaticResource StepperBtnStyle}"
                                            Click="BtnRowsPlus_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Button x:Name="BtnSearch"
                                Width="90"
                                Height="38"
                                Content="검색"
                                Style="{StaticResource SearchButtonStyle}"
                                Background="#6B8EDB"
                                Click="BtnSearch_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 데이터 목록 -->
            <Border Grid.Row="2" Margin="12,10,12,12"
                    CornerRadius="8"
                    ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Color="#BBBBBB" BlurRadius="10"
                                      ShadowDepth="2" Opacity="0.3"/>
                </Border.Effect>
                <DataGrid x:Name="DgrFestival" MouseDoubleClick="DgrFestival_MouseDoubleClick"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EBEBEB"
                          RowHeaderWidth="0"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          IsReadOnly="True"
                          Background="White"
                          AlternatingRowBackground="#F8F8F8"
                          BorderThickness="0"
                          ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                          RowStyle="{StaticResource DgRowStyle}"
                          CellStyle="{StaticResource DgCellStyle}"
                          FontSize="13">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="순번"
                                            Binding="{Binding UcSeq}"
                                            Width="55">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#AAAAAA"/>
                                    <Setter Property="FontSize" Value="12"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="대표이미지" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4"
                                            ClipToBounds="True"
                                            Width="66" Height="44"
                                            Margin="4">
                                        <Image Source="{Binding MainImgNormal}"
                                               Stretch="UniformToFill"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="축제명"
                                            Binding="{Binding Title}"
                                            Width="180">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#222222"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="구군"
                                            Binding="{Binding GugunNm}"
                                            Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#555555"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="주소"
                                            Binding="{Binding Addr1}"
                                            Width="220">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#555555"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="기간"
                                            Binding="{Binding UsageDayWeekAndTime}"
                                            Width="175">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#444444"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="내용"
                                            Binding="{Binding ItemCntnts}"
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#777777"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </DockPanel>
</mah:MetroWindow>
