<ui:FluentWindow x:Class="WpfCctvMonitorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:WpfCctvMonitorApp"
        mc:Ignorable="d" WindowStartupLocation="CenterScreen"
        Height="800" Width="1500" 
        Loaded="Window_LoadedAsync" Closed="Window_Closed" Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <ui:TitleBar 
            x:Name="TlbMain" Grid.Row="0"
            CloseWindowByDoubleClickOnIcon="True">
            
        </ui:TitleBar>
        <!-- 메인화면 Grid -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>


            <!-- Col0 : 도로구분, 지역검색 필터 영역 -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <GroupBox Header="도로 구분" Margin="0,0,0,12">
                    <StackPanel Margin="10">
                        <ToggleButton x:Name="TglRoadType" Height="54" 
                                      FontSize="16" FontWeight="SemiBold"
                                      Content="🛣  고속도로" Checked="TglRoadType_Checked" Unchecked="TglRoadType_Unchecked"> 
                        </ToggleButton>
                        <!--<Button x:Name="BtnExpress" Height="54" Margin="0,4" Content="🛣  고속도로" Click="BtnExpress_Click"/>
                        <Button x:Name="BtnNational" Height="54" Margin="0,8,0,4" Content="🛡  국도" Click= "BtnNational_Click"/>-->
                        <Button Height="54" Margin="0,8,0,4" Content="★  즐겨찾기"/>
                    </StackPanel>
                    
                </GroupBox>
                <!--<GroupBox Header="지역 검색" Margin="0,0,0,12">
                    <StackPanel Margin="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="42"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Height="36"
                                     VerticalContentAlignment="Center"
                                     Text="부산"/>
                            <Button Grid.Column="1"
                                    Content="🔍"/>
                        </Grid>

                        <TextBlock Text="예) 부산, 마산, 경부선"
                                   Foreground="Gray"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </GroupBox>-->

                <GroupBox Header="상세 필터">
                    <StackPanel Margin="10">

                        <TextBlock Text="지역"/>
                        <ComboBox x:Name="CboRegions" Height="34" Margin="0,4,0,10" SelectionChanged="CboRegions_SelectionChanged">
                            
                        </ComboBox>

                        <!--<TextBlock Text="노선"/>
                        <ComboBox Height="34" Margin="0,4,0,10">
                            <ComboBoxItem Content="전체" IsSelected="True"/>
                            <ComboBoxItem Content="경부고속도로"/>
                            <ComboBoxItem Content="국도 25호선"/>
                        </ComboBox>

                        <TextBlock Text="방향"/>
                        <ComboBox Height="34" Margin="0,4,0,14">
                            <ComboBoxItem Content="전체" IsSelected="True"/>
                            <ComboBoxItem Content="서울 방향"/>
                            <ComboBoxItem Content="부산 방향"/>
                        </ComboBox>-->

                        <Button x:Name="BtnSearch" Height="38"
                                Content="검색"
                                Background="#B7D7F5" Click="BtnSearch_Click"/>

                        <Button Height="38"
                                Margin="0,8,0,0"
                                Content="초기화" x:Name="BtnInit" Click="BtnInit_Click"/>
                    </StackPanel>
                </GroupBox> 
            </StackPanel>
            
            <!-- Col1 : CCTV 목록 영역 -->
            <GroupBox x:Name="GrbCctv" Grid.Column="1" Header="CCTV 목록  (총 125건)" Margin="0,0,10,0">
                <DockPanel Margin="8">

                    <StackPanel DockPanel.Dock="Bottom">
                            <!-- Separator Margin="0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Width="34" Content="|&lt;"/>
                                <Button Width="34" Content="&lt;" Margin="4,0"/>
                                <Button Width="34" Content="1" Margin="4,0"/>
                                <Button Width="34" Content="2" Margin="4,0"/>
                                <Button Width="34" Content="3" Margin="4,0"/>
                                <TextBlock Text="..." VerticalAlignment="Center" Margin="8,0"/>
                                <Button Width="34" Content="13" Margin="4,0"/>
                                <Button Width="34" Content="&gt;" Margin="4,0"/>
                                <Button Width="34" Content="&gt;|" Margin="4,0"/>
                            </StackPanel -->
                    </StackPanel>

                    <ListBox x:Name="LsbCctv" SelectionChanged="LsbCctv_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="58" Height="58" BorderBrush="#CCC" BorderThickness="1">
                                        <TextBlock Text="📹" FontSize="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="10,0">
                                        <TextBlock Text="{Binding CctvName}"
                                                   FontWeight="Bold"
                                                   FontSize="15"/>
                                        <TextBlock Text="{Binding CctvFormat}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                                               Text="☆"
                                               FontSize="24"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <!--<ListBoxItem IsSelected="True">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="58" Height="58" BorderBrush="#CCC" BorderThickness="1">
                                    <TextBlock Text="📹" FontSize="30"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="10,0">
                                    <TextBlock Text="경부선 건천휴게소(부산)"
                                               FontWeight="Bold"
                                               FontSize="15"/>
                                    <TextBlock Text="경부고속도로 76K"/>
                                    <TextBlock Text="부산 방향"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="☆"
                                           FontSize="24"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </ListBoxItem>-->

                    </ListBox>
                </DockPanel>
            </GroupBox>
            
            <!-- Col2 : CCTV 동영상/정지영상, 상세정보 영역 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="55*"/>
                    <RowDefinition Height="45*"/>
                </Grid.RowDefinitions>

                <!-- 상단 CCTV 영역 -->
                <GroupBox Grid.Row="0" Header="CCTV 영상" Margin="0,0,0,10">
                    <Border Background="#333" CornerRadius="10" Margin="10">
                        <vlc:VideoView x:Name="VvwScreen"/>
                    </Border>
                </GroupBox>

                <!-- 하단 지도, 상세정보영역 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <!-- 지도영역 -->
                    <GroupBox Grid.Column="0" Header="지도" Margin="0,0,10,0">
                        <Border Margin="8" Background="#E6E6E6" BorderBrush="#CCC" BorderThickness="1">
                            <!--<TextBlock Text="지도 영역&#10;WebView2 + Leaflet 표시 예정"
                                       FontSize="24"
                                       TextAlignment="Center"
                                       Foreground="#555"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>-->
                            <wv2:WebView2 x:Name="WvwMap"/>
                        </Border>
                    </GroupBox>

                    <!-- 상세정보 영역 -->
                    <GroupBox Grid.Column="1" Header="CCTV 정보">
                        <StackPanel Margin="12">

                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="CCTV명" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtCctvName" Grid.Column="1" Text="경부선 건천휴게소(부산)"/>
                            </Grid>

                            <!--<Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="도로명" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtRoadName" Grid.Column="1" Text="경부고속도로"/>
                            </Grid>-->

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="노선" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtRoadName" Grid.Column="1" Text="경부선 76K"/>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TxtDerection" Text="방향" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="부산 방향"/>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TxtCoordY" Text="위도" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="35.371234"/>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TxtCoordX" Text="경도" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="129.123456"/>
                            </Grid>

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="TxtCctvFormat" Text="영상 종류" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="HLS"/>
                            </Grid>

                            <Button Height="38"
                                    Margin="0,24,0,0"
                                    Content="★ 즐겨찾기 추가"/>
                        </StackPanel>
                    </GroupBox>

                </Grid>

            </Grid>
        </Grid>
        
        <!-- 하단 상태바 Border -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtConnStat" Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="● 연결 상태 : 정상"
                           Foreground="Green"/>

                <TextBlock x:Name="TxtSelCctvName" Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="선택 CCTV : 경부선 건천휴게소(부산)"/>

                <TextBlock x:Name="TxtSelCctvUrl" Grid.Column="2"
                           VerticalAlignment="Center"
                           Text="영상 URL : http://cctvsec.ktict.co.kr/204/..."/>

                <TextBlock x:Name="TxtLastUpdateState" Grid.Column="3"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Text="마지막 업데이트 : 14:30:25  ⟳"/>
            </Grid>
            
        </Border> 
        
        <!-- WPF UI용 다이얼로그--><!--
        <ui:ContentDialogHost x:Name="RootContentDialogHost" Grid.Row="0"></ui:ContentDialogHost>-->
        
        
        
    </Grid>
</ui:FluentWindow>
