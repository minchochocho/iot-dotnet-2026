<Window x:Class="WpfMvvm02.Views.DivisionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconpacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:WpfMvvm02.Views"
        mc:Ignorable="d"
        Title="DivisionView" Height="458" Width="998"
        mah:DialogParticipation.Register="{Binding}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" FontSize="24" Margin="10,0,0,0" Text="책장르 관리"/>
        <DataGrid Grid.Row="1" Grid.Column="0" Margin="5"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  ItemsSource="{Binding Divisions}"
                  SelectedItem="{Binding SelectedDivision}">

            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding DivCode}" Header="장르코드"/>
                <DataGridTextColumn Binding="{Binding DivName}" Header="장르명"/>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="1" Grid.Column="1" Margin="5" Header="상세">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="*"/>
                    
                    <RowDefinition Height="Auto"/>
                    
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="장르코드" Margin="3"/>
                <TextBox Grid.Row="1" 
                         mah:TextBoxHelper.Watermark="장르 코드" 
                         mah:TextBoxHelper.ClearTextButton="True"
                         Margin="3"
                         Text=""/>
                
                <TextBlock Grid.Row="2" Text="장르명" Margin="3"/>
                <TextBox Grid.Row="3" 
                         mah:TextBoxHelper.Watermark="장르 명" 
                         mah:TextBoxHelper.ClearTextButton="True"
                         Margin="3"
                         Text=""/>

                <StackPanel Grid.Row="5" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="초기화" Margin="0,0,5,0"
                            Style="{StaticResource MahApps.Styles.Button.MetroSquare.Accent}"
                            Background="ForestGreen"/>
                    <Button Content="저장" Margin="0,0,5,0"
                            Style="{StaticResource MahApps.Styles.Button.MetroSquare.Accent}"/>
                    <Button Content="삭제" Margin="0,0,5,0"
                            Style="{StaticResource MahApps.Styles.Button.MetroSquare.Accent}"
                            Background="OrangeRed"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
