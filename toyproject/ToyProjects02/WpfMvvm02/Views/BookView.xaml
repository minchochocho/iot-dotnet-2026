<UserControl x:Class="WpfMvvm02.Views.BookView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconpacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:WpfMvvm02.Views"
        mc:Ignorable="d"
        Height="458" Width="998"
        mah:DialogParticipation.Register="{Binding}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" FontSize="24" Margin="10,0,0,0" Text="책장르 관리"/>
        <DataGrid Grid.Row="1" Grid.Column="0" Margin="5"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  ItemsSource="{Binding Books}"
                  SelectedItem="{Binding SelectedBook}">

            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding BookIdx}" Header="순번"/>
                <DataGridTextColumn Binding="{Binding DivCode}" Header="장르명"/>
                <DataGridTextColumn Binding="{Binding BookName}" Header="책제목"/>
                <DataGridTextColumn Binding="{Binding Author}" Header="저자"/>
                <DataGridTextColumn Binding="{Binding ReleaseDt, StringFormat='yyyy-MM-dd'}" Header="출판일"/>
                <DataGridTextColumn Binding="{Binding Isbn}" Header="ISBN"/>
                <DataGridTextColumn Binding="{Binding Price, StringFormat={}{0:N0}원}" Header="책가격"/>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="1" Grid.Column="1" Margin="5" Header="상세">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="*"/>

                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <mah:NumericUpDown Grid.Row="0" Margin="3" IsReadOnly="True"
                                   mah:TextBoxHelper.AutoWatermark="True"
                                   mah:TextBoxHelper.Watermark="순번"
                                   mah:TextBoxHelper.WatermarkAlignment="Left"
                                   Value="{Binding SelectedBook.BookIdx}"/>

                
                <ComboBox Grid.Row="1" Margin="3"
                          mah:TextBoxHelper.Watermark="장르명" 
                          	
                          SelectedValuePath="DivCode"
                          DisplayMemberPath="DivName"
                          ItemsSource="{Binding Divisions}"
                          SelectedValue="{Binding SelectedBook.DivCode}"/>

                <TextBox  Grid.Row="2"  Margin="3"
                          mah:TextBoxHelper.AutoWatermark="True"
                          mah:TextBoxHelper.Watermark="책제목" 
                          mah:TextBoxHelper.ClearTextButton="True"
                          Text="{Binding SelectedBook.BookName}"
                          />

                <TextBox  Grid.Row="3"  Margin="3"
                          mah:TextBoxHelper.AutoWatermark="True"
                          mah:TextBoxHelper.Watermark="저자" 
                          mah:TextBoxHelper.ClearTextButton="True"
                          Text="{Binding SelectedBook.Author}"
                          />


                <DatePicker  Grid.Row="4"  Margin="3"
                          mah:TextBoxHelper.AutoWatermark="True"
                          mah:TextBoxHelper.Watermark="출판일" 
                          mah:TextBoxHelper.ClearTextButton="True"
                          SelectedDate="{Binding SelectedBook.ReleaseDt}"
                          />

                <TextBox  Grid.Row="5"  Margin="3"
                          mah:TextBoxHelper.AutoWatermark="True"
                          mah:TextBoxHelper.Watermark="ISBN" 
                          mah:TextBoxHelper.ClearTextButton="True"
                          Text="{Binding SelectedBook.Isbn}"
                          />

                <mah:NumericUpDown Grid.Row="6" Margin="3"
                                   Minimum="1000" Interval="100"
                                   mah:TextBoxHelper.AutoWatermark="True"
                                   mah:TextBoxHelper.Watermark="책가격"
                                   mah:TextBoxHelper.WatermarkAlignment="Left"
                                   Value="{Binding SelectedBook.Price}"/>

                <StackPanel Grid.Row="8" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="초기화" Margin="0,0,5,0"
                            Style="{StaticResource MahApps.Styles.Button.MetroSquare.Accent}"
                            Background="ForestGreen"
                            Command="{Binding ResetCommand}"/>
                    
                    <Button Content="저장" Margin="0,0,5,0"
                            Style="{StaticResource MahApps.Styles.Button.MetroSquare.Accent}"
                    Command="{Binding SaveasyncCommand}"/>
                    
                    <Button Content="삭제" Margin="0,0,5,0"
                            Style="{StaticResource MahApps.Styles.Button.MetroSquare.Accent}"
                            Background="OrangeRed"
                    Command="{Binding DeleteCommand}"/>
                    
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
