<mah:MetroWindow x:Class="WpfProductAdmin.ProductCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:local="clr-namespace:WpfProductAdmin"
        mc:Ignorable="d"
        Title="상품 등록" Height="360" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="상품명" FontWeight="Bold"/>
        <TextBox x:Name="TxtProductName" Grid.Row="1" Height="32" Margin="0,5,0,10"/>

        <TextBlock Grid.Row="2" Text="카테고리" FontWeight="Bold"/>
        <TextBox x:Name="TxtCategory" Grid.Row="3" Height="32" Margin="0,5,0,10"/>

        <TextBlock Grid.Row="4" Text="가격" FontWeight="Bold"/>
        <mah:NumericUpDown x:Name="NudPrice"
                           Grid.Row="5"
                           Height="32"
                           Margin="0,5,0,10"
                           Minimum="0"
                           Value="0"/>

        <TextBlock Grid.Row="6" Text="재고" FontWeight="Bold"/>
        <mah:NumericUpDown x:Name="NudStock"
                           Grid.Row="7"
                           Height="32"
                           Margin="0,5,0,10"
                           Minimum="0"
                           Value="0"/>

        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button x:Name="BtnSave"
                    Content="저장"
                    Width="90"
                    Height="35"
                    Margin="0,0,8,0"
                    Click="BtnSave_Click"/>
            <Button x:Name="BtnCancel"
                    Content="취소"
                    Width="90"
                    Height="35"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
