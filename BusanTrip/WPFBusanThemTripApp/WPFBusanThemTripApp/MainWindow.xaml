<controls:MetroWindow x:Class="WPFBusanThemTripApp.MainWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                      mc:Ignorable="d"
                      Title="Busan Trip Explorer"
                      Height="900"
                      Width="1400"
                      MinHeight="740"
                      MinWidth="1200"
                      WindowStartupLocation="CenterScreen"
                      UseLayoutRounding="True"
                      SnapsToDevicePixels="True"
                      TitleCharacterCasing="Normal"
                      GlowBrush="{DynamicResource MahApps.Brushes.Accent}">
    <controls:MetroWindow.Resources>
        <ItemsPanelTemplate x:Key="TripItemsPanel3x3">
            <UniformGrid Columns="3" Rows="3" />
        </ItemsPanelTemplate>

        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="18"
                          ShadowDepth="0"
                          Opacity="0.18"
                          Color="#FF000000" />

        <Style x:Key="SurfaceCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Control.Background}" />
            <Setter Property="Effect" Value="{StaticResource CardShadow}" />
        </Style>

        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="FontSize" Value="16" />
        </Style>
    </controls:MetroWindow.Resources>

    <Grid Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Margin="18,16,18,8"
                CornerRadius="14"
                Padding="22,16"
                Background="{DynamicResource MahApps.Brushes.Accent}">
            <DockPanel LastChildFill="False">
                <iconPacks:PackIconMaterial Kind="MapMarkerRadius"
                                            Width="28"
                                            Height="28"
                                            VerticalAlignment="Center"
                                            Foreground="White" />
                <StackPanel Margin="14,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="부산 테마여행"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Text="Busan Theme Travel Explorer"
                               FontSize="12"
                               Foreground="#CCFFFFFF" />
                </StackPanel>

                <TextBlock x:Name="ResultCountText"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="White" />
            </DockPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Margin="18,8,18,8"
                Padding="14"
                Style="{StaticResource SurfaceCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,12,0"
                        CornerRadius="8"
                        Padding="12,0"
                        Background="{DynamicResource MahApps.Brushes.Control.Background}"
                        BorderBrush="{DynamicResource MahApps.Brushes.Border}"
                        BorderThickness="1">
                    <DockPanel LastChildFill="True">
                        <iconPacks:PackIconMaterial Kind="Magnify"
                                                    Width="18"
                                                    Height="18"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0"
                                                    Foreground="{DynamicResource MahApps.Brushes.Gray2}" />
                        <TextBox x:Name="SearchTextBox"
                                 VerticalAlignment="Center"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 controls:TextBoxHelper.Watermark="제목, 구군, 장소 검색"
                                 TextChanged="SearchTextBox_TextChanged" />
                    </DockPanel>
                </Border>

                <ComboBox x:Name="DistrictFilterComboBox"
                          Grid.Column="1"
                          Margin="0,0,8,0"
                          VerticalAlignment="Center"
                          controls:TextBoxHelper.Watermark="구군"
                          SelectionChanged="DistrictFilterComboBox_SelectionChanged" />

                <ComboBox x:Name="SortComboBox"
                          Grid.Column="2"
                          Margin="0,0,12,0"
                          VerticalAlignment="Center"
                          SelectionChanged="SortComboBox_SelectionChanged">
                    <ComboBoxItem IsSelected="True">최신순</ComboBoxItem>
                    <ComboBoxItem>제목순</ComboBoxItem>
                </ComboBox>

                <Button Grid.Column="3"
                        Padding="16,8"
                        Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                        Click="RefreshButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Refresh"
                                                    Width="16"
                                                    Height="16"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0" />
                        <TextBlock Text="새로고침" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2"
              Margin="18,8,18,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.4*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="14"
                    Style="{StaticResource SurfaceCard}">
                <ItemsControl x:Name="TripItemsControl"
                              ItemsPanel="{StaticResource TripItemsPanel3x3}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="7"
                                    Padding="0"
                                    Tag="{Binding}"
                                    Cursor="Hand"
                                    Click="OpenDetailButton_Click"
                                    Background="{DynamicResource MahApps.Brushes.Control.Background}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CardBorder"
                                                CornerRadius="12"
                                                Background="{TemplateBinding Background}"
                                                SnapsToDevicePixels="True">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12"
                                                                  ShadowDepth="0"
                                                                  Opacity="0.15"
                                                                  Color="#FF000000" />
                                            </Border.Effect>
                                            <Grid>
                                                <Border CornerRadius="12"
                                                        ClipToBounds="True"
                                                        Background="{DynamicResource MahApps.Brushes.Gray4}">
                                                    <Image Source="{Binding ThumbnailUrl}"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           Stretch="UniformToFill" />
                                                </Border>

                                                <Border CornerRadius="0,0,12,12"
                                                        VerticalAlignment="Bottom"
                                                        Padding="12,8">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#00000000" Offset="0" />
                                                            <GradientStop Color="#E6000000" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <StackPanel>
                                                        <TextBlock FontSize="15"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Text="{Binding MainTitle}" />
                                                        <TextBlock FontSize="11"
                                                                   Margin="0,2,0,0"
                                                                   Foreground="#DDFFFFFF"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Text="{Binding DistrictAndCategory}" />
                                                    </StackPanel>
                                                </Border>

                                                <ToggleButton Width="34"
                                                              Height="34"
                                                              Margin="8"
                                                              HorizontalAlignment="Right"
                                                              VerticalAlignment="Top"
                                                              ToolTip="즐겨찾기"
                                                              IsChecked="{Binding IsFavorite, Mode=TwoWay}"
                                                              Checked="FavoriteToggleButton_Changed"
                                                              Unchecked="FavoriteToggleButton_Changed">
                                                    <iconPacks:PackIconMaterial Kind="Star"
                                                                                Width="16"
                                                                                Height="16" />
                                                </ToggleButton>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardBorder" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter TargetName="CardBorder" Property="RenderTransformOrigin" Value="0.5,0.5" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <Border Grid.Column="2"
                    Padding="16"
                    Style="{StaticResource SurfaceCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="190" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="260" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            CornerRadius="12"
                            ClipToBounds="True"
                            Background="{DynamicResource MahApps.Brushes.Gray4}">
                        <Image x:Name="DetailImage"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Stretch="UniformToFill" />
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="DetailTitleText"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="21"
                                   TextTrimming="CharacterEllipsis"
                                   Text="여행지를 선택하세요." />

                        <ToggleButton x:Name="DetailFavoriteButton"
                                      Grid.Column="1"
                                      Width="42"
                                      Height="42"
                                      Margin="8,0,0,0"
                                      ToolTip="즐겨찾기"
                                      Checked="DetailFavoriteButton_Changed"
                                      Unchecked="DetailFavoriteButton_Changed">
                            <iconPacks:PackIconMaterial Kind="Star"
                                                        Width="18"
                                                        Height="18" />
                        </ToggleButton>

                        <Button Grid.Column="2"
                                Width="42"
                                Height="42"
                                Margin="8,0,0,0"
                                ToolTip="지도보기"
                                Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                                Click="ShowMapButton_Click">
                            <iconPacks:PackIconMaterial Kind="MapMarker"
                                                        Width="18"
                                                        Height="18" />
                        </Button>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="0,14,0,0"
                            Padding="14"
                            CornerRadius="10"
                            Background="{DynamicResource MahApps.Brushes.Control.Background}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Border}"
                            BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <iconPacks:PackIconMaterial Kind="MapMarkerOutline"
                                                            Width="14"
                                                            Height="14"
                                                            VerticalAlignment="Top"
                                                            Margin="0,2,8,0"
                                                            Foreground="{DynamicResource MahApps.Brushes.Accent}" />
                                <TextBlock x:Name="DetailAddressText"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <iconPacks:PackIconMaterial Kind="PhoneOutline"
                                                            Width="14"
                                                            Height="14"
                                                            Margin="0,2,8,0"
                                                            Foreground="{DynamicResource MahApps.Brushes.Accent}" />
                                <TextBlock x:Name="DetailPhoneText"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <iconPacks:PackIconMaterial Kind="Web"
                                                            Width="14"
                                                            Height="14"
                                                            VerticalAlignment="Top"
                                                            Margin="0,2,8,0"
                                                            Foreground="{DynamicResource MahApps.Brushes.Accent}" />
                                <TextBlock x:Name="DetailHomepageText"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource MahApps.Brushes.Accent}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3"
                            Margin="0,14,0,0"
                            Padding="14"
                            CornerRadius="10"
                            Background="{DynamicResource MahApps.Brushes.Control.Background}"
                            BorderBrush="{DynamicResource MahApps.Brushes.Border}"
                            BorderThickness="1">
                        <ScrollViewer x:Name="DetailDescriptionScrollViewer"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="DetailDescriptionText"
                                       TextWrapping="Wrap"
                                       LineHeight="22"
                                       Text="카드를 누르면 상세 설명이 표시됩니다." />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Pagination -->
        <Border Grid.Row="3"
                Margin="18,8,18,16"
                Padding="10"
                Style="{StaticResource SurfaceCard}">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource NavButton}"
                            ToolTip="이전"
                            Click="PreviousPageButton_Click">
                        <iconPacks:PackIconMaterial Kind="ChevronLeft" Width="18" Height="18" />
                    </Button>

                    <Border MinWidth="120"
                            CornerRadius="8"
                            Padding="14,0"
                            Margin="6,0"
                            Background="{DynamicResource MahApps.Brushes.Control.Background}">
                        <TextBlock x:Name="PageStatusText"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                    </Border>

                    <Button Style="{StaticResource NavButton}"
                            ToolTip="다음"
                            Click="NextPageButton_Click">
                        <iconPacks:PackIconMaterial Kind="ChevronRight" Width="18" Height="18" />
                    </Button>
                </StackPanel>

                <TextBlock x:Name="StatusText"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           FontSize="12"
                           Foreground="{DynamicResource MahApps.Brushes.Gray2}" />
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Border x:Name="LoadingOverlay"
                Grid.RowSpan="4"
                Background="#A6000000"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <controls:ProgressRing Width="70"
                                       Height="70"
                                       IsActive="True" />
                <TextBlock x:Name="LoadingText"
                           Margin="0,12,0,0"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="데이터를 불러오는 중..." />
            </StackPanel>
        </Border>
    </Grid>
</controls:MetroWindow>
